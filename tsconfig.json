{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "modules/accounts/template/lib/accounts/types.ts",
    "modules/accounts/template/lib/accounts/sync.ts",
    "modules/accounts/tests/**/*.ts"
  ]
}
